{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "汇安检测",
  "version": "0.1.0",
  "identifier": "com.huian.inspection",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --dir ../web build",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "汇安检测",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../../api/dist/huian-api"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
